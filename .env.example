# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Mailgun (inbound routing + outbound sending)
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=waynelin.com
MAILGUN_FROM_ADDR=translate@waynelin.com

# Local part of the inbound relay address (translate@MAILGUN_DOMAIN)
RELAY_TOKEN=translate

# Default destination email for translated newsletters
DEFAULT_DEST_EMAIL=wlse66180@gmail.com

# SQLite database path
# On Railway with a /data volume: sqlite+aiosqlite:////data/newsletter_translator.db
DATABASE_URL=sqlite+aiosqlite:///./newsletter_translator.db
