# ---------------------------------------------------------------
# Gmail inbox to poll for incoming newsletters
# ---------------------------------------------------------------
# Forward newsletters to this address and the app will translate them.
IMAP_USER=email.translator.2026@gmail.com

# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
IMAP_PASSWORD=your-gmail-app-password

# How often to check for new emails (seconds)
IMAP_POLL_INTERVAL=60

# ---------------------------------------------------------------
# Outbound SMTP — sends the translated email to the destination
# Can reuse the same Gmail account, or a separate sending address.
# ---------------------------------------------------------------
SMTP_SEND_HOST=smtp.gmail.com
SMTP_SEND_PORT=587
SMTP_SEND_USER=email.translator.2026@gmail.com
SMTP_SEND_PASSWORD=your-gmail-app-password
SMTP_SEND_FROM=email.translator.2026@gmail.com

# ---------------------------------------------------------------
# Anthropic API
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------
# App defaults
# ---------------------------------------------------------------
DEFAULT_DEST_EMAIL=wlse66180@gmail.com
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./newsletter_translator.db
