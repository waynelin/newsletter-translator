# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Outbound SMTP (e.g. Gmail with an App Password)
SMTP_SEND_HOST=smtp.gmail.com
SMTP_SEND_PORT=587
SMTP_SEND_USER=your-sending-address@gmail.com
SMTP_SEND_PASSWORD=your-app-password
SMTP_SEND_FROM=your-sending-address@gmail.com

# Inbound SMTP (port 8025 avoids needing root; use iptables to redirect 25->8025 in production)
SMTP_HOST=0.0.0.0
SMTP_PORT=8025

# Relay address shown to users: forwards sent to RELAY_TOKEN@RELAY_DOMAIN are translated
RELAY_DOMAIN=translate.example.com
RELAY_TOKEN=translate

# Default destination email for translated newsletters
DEFAULT_DEST_EMAIL=wlse66180@gmail.com

# Web app port
APP_PORT=8000

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./newsletter_translator.db
